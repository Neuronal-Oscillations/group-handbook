#!/bin/bash

THIS_SCRIPT=$(basename "$0")

DEBUG=0
ACTION="help"
DOMAIN="AD-OAK"
SERVER="connect.ox.ac.uk" # RFS-CFILESVR03.connect.ox.ac.uk

RFS="${SERVER}/RFS" # RFS01-J

function help {
cat <<EOF

Usage: $(basename "$0") [OPTIONS] <action> [ACTION ARGS]

Global Options:
  -h             Show this help message
  -v             Debug mode (print smbclient command without executing)
  -c <credfile>  Path to credentials file (default: \$RFS_KEY)
                 File should contain: username, password, domain, projname

Actions:
  ls   [dir]            List contents of RFS/<project>[/dir]

  mkdir <dst> [base]    Create directory tree at RFS/<project>/<dst>,
                        optionally rooted at RFS/<project>/<base>

  push  <src> <dst>     Upload local file or directory to RFS/<project>/<dst>

  pull [-d] <src> [dst] Download file (or directory with -d) from RFS/<project>/<src>
                        to local <dst> (default: current directory)

  rm   [-d] <src>       Delete file (or directory tree with -d) at RFS/<project>/<src>

Examples:
  $(basename "$0") ls                             # list content of RFS/<project>/
  $(basename "$0") ls MyDir/                      # list content of RFS/<project>/MyDir/

  $(basename "$0") mkdir NewDir                   # create RFS/<project>/NewDir
  $(basename "$0") mkdir SubDir NewDir            # create RFS/<project>/NewDir/SubDir

  $(basename "$0") push MyDir RemoteDir           # upload MyDir    → RFS/<project>/RemoteDir/MyDir
  $(basename "$0") push MyFile.txt RemoteDir      # upload MyFile   → RFS/<project>/RemoteDir/MyFile.txt

  $(basename "$0") pull RemoteDir/MyFile.txt .    # download file   → ./MyFile.txt
  $(basename "$0") pull -d RemoteDir/MyDir .      # download dir    → ./MyDir/

  $(basename "$0") rm RemoteDir/MyFile.txt        # delete file from RFS
  $(basename "$0") rm -d RemoteDir                # delete directory tree from RFS

  $(basename "$0") -v push MyDir RemoteDir        # dry-run: print smbclient command only
  $(basename "$0") -c ~/my_creds push MyDir Dst   # use custom credentials file
EOF
}

function resolve_credfile {
    [[ -z "$CREDFILE" ]] && CREDFILE="${RFS_KEY}"
}

function get_proj_dir {
    if [[ -f "$CREDFILE" ]]; then
        # Extract project directory.
        RFS_PROJ_DIR=$(grep -i "^projname" "$CREDFILE" | sed -E 's/^projname[[:space:]]*=[[:space:]]*//')
        if [[ -z "$RFS_PROJ_DIR" ]]; then
            echo "" >&2
            echo "Variable 'projname' not found in $CREDFILE" >&2
            echo "Not setting project dir as root directory." >&2
            echo "" >&2
        fi
    fi
}


# ── smbclient command builders ───────────────────────────────────────────────

function rfs_ls {
    #ls the remote directory
    local REMOTE=$1
    local cmd="${REMOTE:+cd ${REMOTE}; }ls"
    echo "${cmd}"
}

function rfs_mkdir {
    local target=$1
    local remotepath=$2

    IFS='/' read -ra folders <<< "$target"

    local cmd="prompt OFF; "

    # If a starting remote path was provided, move there first
    if [[ -n "${remotepath}" ]]; then
        cmd+="cd ${remotepath}; "
    fi

    # Build the chain of mkdir/cd commands
    for folder in "${folders[@]}"; do
        if [[ -n "${folder}" ]]; then
            cmd+="mkdir ${folder}; cd ${folder}; "
        fi
    done
    echo "Creating Directories..." >&2
    echo "${cmd}"
}

function rfs_push {
    local LOCAL=$1
    local REMOTE="${2:-.}"

    echo "pushing to RFS (${LOCAL} to ${REMOTE})" >&2
    #push data into RFS
    if [[ -z "${LOCAL}" ]] ; then
        echo "ERROR script requires at least one file/directory - local file/directory to push to RFS" >&2
        return 1
    fi

    if [[ ! -r "${LOCAL}" ]] ; then
        echo "${LOCAL} does not seem to exist (or no read access), aborting" >&2
        return 1
    fi

    local LOCAL_DIR=$(dirname "${LOCAL}")
    local LOCAL_NAME=$(basename "${LOCAL}")

    echo "pushing ${LOCAL} to ${REMOTE}" >&2

    #if ${LOCAL} is a dir or file...
    if [[ -d "${LOCAL}" ]] ; then
        local cmd="prompt OFF; recurse ON; lcd ${LOCAL}; mkdir ${REMOTE}; cd ${REMOTE}; mkdir ${LOCAL_NAME}; cd ${LOCAL_NAME}; mput *"
    elif [[ -f "${LOCAL}" ]]; then
        local cmd="prompt OFF; recurse ON; lcd ${LOCAL_DIR}; mkdir ${REMOTE}; cd ${REMOTE}; put ${LOCAL_NAME}"
    else
        echo "ERROR: File or Folder does not exist." >&2
    fi
    echo "${cmd}"
}

function rfs_pull {
    local IS_DIR=$1
    local REMOTE=$2
    local DEST="${3:-.}"

    echo "fetching data from RFS (${REMOTE} to ${DEST})" >&2
    if [[ -z "${REMOTE}" ]] ; then
        echo "ERROR: script requires at least one file/directory - local file/directory to pull from RFS" >&2
        return 1
    fi

    local REMOTE_DIR=$(dirname "${REMOTE}")
    local REMOTE_NAME=$(basename "${REMOTE}")

    if [[ ! -d "${DEST}" ]] ; then
        echo "ERROR: ${DEST} does not appear to exist or is not a directory." >&2
        return 1
    fi

    if [[ "${IS_DIR}" == false ]]; then
        local cmd="prompt OFF; recurse ON; lcd ${DEST}; cd ${REMOTE_DIR}; get ${REMOTE_NAME}"
    else
        local cmd="prompt OFF; recurse ON; lcd ${DEST}; cd ${REMOTE}; mget *"
    fi
    echo "${cmd}"
}

function rfs_rm {
    local IS_DIR=$1
    local TARGET=$2

    if [[ -z "${TARGET}" ]]; then
        echo "ERROR: Usage rfs_rm <remote_path>" >&2
        return 1
    fi

    echo "Deleting $TARGET from RFS..." >&2
    if [[ "${IS_DIR}" == false ]]; then
        local cmd="prompt OFF; del ${TARGET}"
    else
        local cmd="prompt OFF; deltree ${TARGET}"
    fi
    echo "${cmd}"

}

# ── Argument parsing ─────────────────────────────────────────────────────────

while getopts "hvc:" opts ; do
    case $opts in
        h) help; exit 0 ;;
        v) DEBUG=1;;
        c) CREDFILE="$OPTARG" ;;
        *) echo "illegal option" >&2; help; exit 62 ;;
    esac
done
shift $((OPTIND-1))

resolve_credfile
get_proj_dir

case "${1:-help}" in
  help) ACTION="help";;
  ls) ACTION="ls"; echo "listing files in RFS";;
  push) ACTION="push"; echo "pushing files to RFS";;
  mkdir) ACTION="mkdir";echo "creating a directory in RFS";;
  pull) ACTION="pull"; echo "pulling files from RFS";;
  rm) ACTION="rm"; echo "deleting file from RFS";;
  *) echo "Unknown action $1 - action can be ls, push, pull, mkdir, rm, help"
     help
     exit 63
     ;;
esac
shift

# check for pull|rm
IS_DIR=false
if [[ "$1" == "-d" ]]; then
    IS_DIR=true
    shift
fi
case $ACTION in
    help) help; exit 0;;
    ls) CMD=$(rfs_ls "$1");;
    push) CMD=$(rfs_push "$1" "$2");;
    mkdir) CMD=$(rfs_mkdir "$1" "$2");;
    pull) CMD=$(rfs_pull "$IS_DIR" "$1" "$2");;
    rm) CMD=$(rfs_rm "$IS_DIR" "$1");;
esac

if [[ -z "$CREDFILE" ]]; then
    SMB_BASE_CMD="-t 60000"
else
    SMB_BASE_CMD="-A ${CREDFILE} -t 60000"
fi

if [[ -z "$CMD" ]]; then
    echo "ERROR: No command generated." >&2
    exit 1
fi

if [[ -n "$RFS_PROJ_DIR" ]]; then
    CMD="cd ${RFS_PROJ_DIR}; ${CMD}"
fi

if [[ $DEBUG -eq 1 ]]; then
    echo "DEBUG command:"
    echo "smbclient \"//${RFS}\" $SMB_BASE_CMD -c \"${CMD}\""
    exit 0
else
    smbclient "//${RFS}" ${SMB_BASE_CMD} -c "${CMD}" && exit 0
fi
exit 1

#!/bin/bash

CLUSTER="htc"
JOBS=""
SCOPE="last"
UPDATE_TIME=10s
LIVE="false"

MEM=16G
CPUs=8
GPU=""
TIME="08:00:00"
PARTITION="short"
CLUSTER="htc"
ENV4SCRIPT=""
ENVACT=""
INTERPRETER="bash"


# ── colours ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'

# ── help ─────────────────────────────────────────────────────────────────────
function help {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS] <action> [ACTION OPTIONS]

Global options:
  -C <cluster>   Target cluster (default: htc)
  -h             Show this help message

Actions:
  help           Show this help message
  list           List view of your jobs
  usage          Show current resource usage for your jobs (uses sstat)
  cancel         Cancel your jobs
  submit         Submit a script as a SLURM job (must be .sh or .py)

Options for list / usage / cancel:
  (none)         Operate on the most recently submitted job (default)
  -a             Operate on ALL jobs belonging to $USER on the cluster
  -j <id[,id]>   Operate on the specified comma-separated job IDs
  -l             Live update every $UPDATE_TIME (works with 'list' and 'usage' only)
  -C <cluster>   Override cluster for this action

Options for submit:
  -e <env>       Path to conda / mamba environment to activate before running
  -m <mem>       Memory per job (default: $MEM)
  -c <cpus>      CPUs per task (default: $CPUs)
  -t <time>      Wall time limit (default: $TIME)
  -p <partition> Partition to submit to (default: $PARTITION)
  -C <cluster>   Override cluster for this action
  -g <gpu>       Set GPU specification (default: no GPU)

Examples:
  $(basename "$0") -C htc list              # list current jobs on 'htc'
  $(basename "$0") usage -l                 # report for last job, live update
  $(basename "$0") -C arc usage -a          # report for all jobs on 'arc'
  $(basename "$0") cancel                   # cancel last job (with confirmation)
  $(basename "$0") cancel -a                # cancel all jobs
  $(basename "$0") cancel -j 12345,12346    # cancel specific jobs
  $(basename "$0") submit MyScript.sh       # submit bash script with defaults
  $(basename "$0") submit -e MyEnv -g 1 -m 32G -c 16 -t 24:00:00 -p long MyScript.py arg1 arg2
EOF
}

function submit {
    [[ -z "$1" ]] && { echo -e "${RED}ERROR: No script provided.${NC}" >&2; help; exit 1; }

    mkdir -p "$DATA/logs"
    local SCRIPT_PATH="$(realpath "$1")"
    local SCRIPT_NAME="$(basename "${1%.*}")"
    local SCRIPT_EXT="${1##*.}"

    [[ -n "${ENV4SCRIPT}"  ]] && ENVACT="source activate $(realpath "${ENV4SCRIPT}")"
    case $SCRIPT_EXT in
        sh)   INTERPRETER="bash" ;;
        py)   INTERPRETER="python" ;;
        *) echo -e "${RED}ERROR: Function not implemented for .${SCRIPT_EXT} scripts yet.${NC}" >&2; help; exit 1 ;;
    esac
    local GPU_DIRECTIVE=""
    [[ -n "$GPU" ]] && GPU_DIRECTIVE="#SBATCH --gres=gpu:${GPU}"
JOBID=$(sbatch --parsable <<EOF
#!/bin/bash
#SBATCH --partition=$PARTITION
#SBATCH --job-name=$SCRIPT_NAME
#SBATCH --cpus-per-task=$CPUs
#SBATCH --mem=$MEM
#SBATCH --time=$TIME
#SBATCH --clusters=$CLUSTER
#SBATCH --output=$DATA/logs/$SCRIPT_NAME-%j.log
$GPU_DIRECTIVE

# source basic and, if requested, activate environment
source $HOME/.bashrc
$ENVACT

$INTERPRETER "${SCRIPT_PATH}" "${@:2}"

EOF
)
[[ $CLUSTER == "all" ]] && CLUSTER=$(echo "$JOBID" | cut -d';' -f2)
JOBID=$(echo "$JOBID" | cut -d';' -f1)
echo -e "${CYAN}Submitted job ${JOBID} to ${CLUSTER} ${NC}"
}

function get_jobs {
    # JOBS already set explicitly via -j: use as-is.
    if [[ -n "$JOBS" ]]; then
        return 0
    fi

    # last line is the most recently submitted job.
    local all_ids
    all_ids=$(squeue -u "$USER" --clusters "$CLUSTER" -h -o '%i %V' 2>/dev/null | sort -k2 | awk '{print $1}')

    if [[ -z "$all_ids" ]]; then
        echo -e "${YELLOW}No jobs found for $USER on cluster '$CLUSTER'.${NC}" >&2
        return 0
    fi

    if [[ "$SCOPE" == "all" ]]; then
        JOBS=$(echo "$all_ids" | tr '\n' ',' | sed 's/,$//')
    else
        # Default: most recently submitted job only.
        JOBS=$(echo "$all_ids" | tail -n 1)
    fi
}

function cancel_jobs {
    get_jobs

    if [[ -z "$JOBS" ]]; then
        echo -e "${YELLOW}Nothing to cancel.${NC}"
        return 0
    fi

    echo -e "${CYAN}Jobs to cancel on '$CLUSTER': ${JOBS}${NC}"
    read -r -p "Are you sure you want to cancel these jobs? [y/N] " confirm
    if [[ "${confirm,,}" != "y" ]]; then
        echo "Aborted."
        return 0
    fi

    IFS=',' read -ra JOB_ARRAY <<< "$JOBS"
    if scancel --clusters "$CLUSTER" "${JOB_ARRAY[@]}"; then
        echo -e "${CYAN}Cancelled: ${JOBS}${NC}"
    else
        echo -e "${RED}scancel returned an error – check output above.${NC}" >&2
        return 1
    fi
}

function res_use {
    get_jobs

    if [[ -z "$JOBS" ]]; then
        echo -e "${YELLOW}No jobs to report on.${NC}"
        return 0
    fi
    ec=0
    IFS=',' read -ra JOB_ARRAY <<< "$JOBS"
    while true; do
        [[ "$LIVE" == "true" ]] && clear
        for JOB in "${JOB_ARRAY[@]}"; do
            echo -e "${CYAN}── sstat report for job $JOB ──${NC}"
            sstat -j "$JOB" --format=AveCPU,AveRSS,MaxRSS \
            || { echo -e "${RED}sstat failed for job $JOB${NC}" >&2; ec=1; }
        done
        [[ "$LIVE" == "false" ]] && exit $ec
        sleep $UPDATE_TIME
    done
}

function list_view {
    while true; do
        [[ "$LIVE" == "true" ]] && clear
        echo -e "${CYAN}[$(date '+%Y-%m-%d %H:%M:%S')]  $USER @ $CLUSTER${NC}"
        squeue -u "$USER" --clusters "$CLUSTER"
        [[ "$LIVE" == "false" ]] && exit 0
        sleep $UPDATE_TIME
    done
}

# ─────────────────────────────────────────────────────────────────────────────
# Parse global options (before the action keyword)
# ─────────────────────────────────────────────────────────────────────────────
while getopts ":hC:" opts; do
    case $opts in
        h) help; exit 0 ;;
        C) CLUSTER="$OPTARG" ;;
        :) echo -e "${RED}Option -$OPTARG requires an argument.${NC}" >&2; help; exit 1 ;;
        *) echo -e "${RED}Illegal option: -$OPTARG${NC}" >&2; help; exit 62 ;;
    esac
done
shift $((OPTIND - 1))
OPTIND=1   # reset for second getopts pass below

# ─────────────────────────────────────────────────────────────────────────────
# Determine action
# ─────────────────────────────────────────────────────────────────────────────
case "${1:-help}" in
    help)   ACTION="help" ;;
    list)   ACTION="list" ;;
    usage)  ACTION="usage" ;;
    cancel) ACTION="cancel" ;;
    submit) ACTION="submit" ;;
    *)      echo -e "${RED}Unknown action: $1${NC}" >&2; help; exit 63 ;;
esac
shift

# ─────────────────────────────────────────────────────────────────────────────
# Parse per-action options (after the action keyword)
# ─────────────────────────────────────────────────────────────────────────────
if [[ "$ACTION" == "submit" ]]; then
    while getopts ":e:m:c:t:p:g:C:" opts; do
        case $opts in
            e) ENV4SCRIPT="$OPTARG" ;;
            m) MEM="$OPTARG" ;;
            c) CPUs="$OPTARG" ;;
            t) TIME="$OPTARG" ;;
            p) PARTITION="$OPTARG" ;;
            g) GPU="$OPTARG" ;;
            C) CLUSTER="$OPTARG" ;;
            :) echo -e "${RED}Option -$OPTARG requires an argument.${NC}" >&2; help; exit 1 ;;
            *) echo -e "${RED}Illegal option for submit: -$OPTARG${NC}" >&2; help; exit 62 ;;
        esac
    done
else
    while getopts ":aj:lC:" opts; do
        case $opts in
            a) SCOPE="all" ;;
            j) JOBS="$OPTARG" ;;
            l) LIVE="true" ;;
            C) CLUSTER="$OPTARG" ;;
            :) echo -e "${RED}Option -$OPTARG requires an argument.${NC}" >&2; help; exit 1 ;;
            *) echo -e "${RED}Illegal option: -$OPTARG${NC}" >&2; help; exit 62 ;;
        esac
    done
fi
shift $((OPTIND - 1))

# ─────────────────────────────────────────────────────────────────────────────
# Dispatch
# ─────────────────────────────────────────────────────────────────────────────
case $ACTION in
    help)   help ;;
    list)   list_view ;;
    usage)  res_use ;;
    cancel) cancel_jobs ;;
    submit) submit "${@}" ;;
esac

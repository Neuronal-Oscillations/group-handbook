#!/bin/bash

JOBS=""
SCOPE="last"
UPDATE_TIME=10
LIVE="false"

MEM=16G
CPUs=8
GPU=""
TIME="08:00:00"
PARTITION="short"
CLUSTER="htc"
ENV4SCRIPT=""
ENVACT=""
INTERPRETER="bash"
SELECT="false"


# ── colours ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'

# ── help ─────────────────────────────────────────────────────────────────────
function help {
    cat <<EOF
Usage: $(basename "$0") <action> [ACTION OPTIONS]

Actions:
  help           Show this help message
  list           List view of your jobs
  usage          Show current and maximum memory usage for job ID (uses sstat)
  cancel         Cancel your jobs
  submit         Submit a script as a SLURM batch job (must be .sh or .py)
  log            View log file of job ($DATA/logs/<job_name>-<job_id>.log)

Options for list:
  (none)         Show output once
  -l             Live update every $UPDATE_TIME seconds
  -C <cluster>   Show result for specified cluster (default: $CLUSTER)

Options for usage:
  (none)         Show output of the most recently submitted job
  -s             Shows list of jobs. Select job via index.
  -l             Live update every $UPDATE_TIME seconds
  -j <id>        Show output for a specific job ID
  -C <cluster>   Show result for specified cluster (default: $CLUSTER)

Options for cancel:
  (none)         Cancel the most recently submitted job
  -a             Cancel ALL jobs belonging to $USER on the specified cluster
  -s             Shows list of jobs. Select via comma seperated indices.
  -j <id[,id]>   Cancel specified comma-separated job IDs
  -C <cluster>   Operate on jobs for specified cluster (default: $CLUSTER)

Options for submit:
  -e <env>       Path to conda / mamba environment to activate before running (default: none)
  -m <mem>       Memory requested (default: $MEM)
  -c <cpus>      Number of CPUs requested (default: $CPUs)
  -t <time>      Wall time limit (default: $TIME)
  -p <partition> Partition to submit to (default: $PARTITION)
  -C <cluster>   Start job on specified cluster (default: $CLUSTER)
  -g <gpu>       Set GPU specification (default: no GPU)

Options for log:
  (none)         Show output of the most recently submitted job
  -l             Live update
  -s             Shows list of jobs. Select job via index.
  -j <id>        Show output for a specific job ID
  -C <cluster>   Show result for specified cluster (default: $CLUSTER)

Examples:
  $(basename "$0") list                     # list current jobs on $CLUSTER
  $(basename "$0") list -C arc -l           # list current jobs on arc, live update

  $(basename "$0") usage -l                 # report usage for last job, live update
  $(basename "$0") usage -j 12345           # report usage for job 12345

  $(basename "$0") cancel                   # cancel last job on $CLUSTER
  $(basename "$0") cancel -s                # cancel selected jobs on $CLUSTER
  $(basename "$0") cancel -a -C arc         # cancel all jobs on arc
  $(basename "$0") cancel -j 12345,12346    # cancel specific jobs on $CLUSTER

  $(basename "$0") submit MyScript.sh       # submit bash script with defaults
  $(basename "$0") submit -e MyEnv -g 1 -m 32G -c 16 -t 24:00:00 -p long MyScript.py arg1 arg2

  $(basename "$0") log -l                   # Show log file for last job, live update
  $(basename "$0") log -j 12345             # Show log file for job 12345
EOF
}

function submit {
    [[ -z "$1" ]] && { echo -e "${RED}ERROR: No script provided.${NC}" >&2; help; exit 1; }

    mkdir -p "$DATA/logs"
    local SCRIPT_PATH="$(realpath "$1")"
    local SCRIPT_NAME="$(basename "${1%.*}")"
    local SCRIPT_EXT="${1##*.}"

    [[ -n "${ENV4SCRIPT}"  ]] && ENVACT="source activate $(realpath "${ENV4SCRIPT}")"
    case $SCRIPT_EXT in
        sh)   INTERPRETER="bash" ;;
        py)   INTERPRETER="python" ;;
        *) echo -e "${RED}ERROR: Function not implemented for .${SCRIPT_EXT} scripts yet.${NC}" >&2; help; exit 1 ;;
    esac
    local GPU_DIRECTIVE=""
    [[ -n "$GPU" ]] && GPU_DIRECTIVE="#SBATCH --gres=gpu:${GPU}"
JOBID=$(sbatch --parsable <<EOF
#!/bin/bash
#SBATCH --partition=$PARTITION
#SBATCH --job-name=$SCRIPT_NAME
#SBATCH --cpus-per-task=$CPUs
#SBATCH --mem=$MEM
#SBATCH --time=$TIME
#SBATCH --clusters=$CLUSTER
#SBATCH --output=$DATA/logs/$SCRIPT_NAME-%j.log
#SBATCH --error=$DATA/logs/$SCRIPT_NAME-%j.log
$GPU_DIRECTIVE

# source bashrc and, if requested, activate environment
source $HOME/.bashrc
$ENVACT

$INTERPRETER "${SCRIPT_PATH}" "${@:2}"

EOF
)
[[ $CLUSTER == "all" ]] && CLUSTER=$(echo "$JOBID" | cut -d';' -f2)
JOBID=$(echo "$JOBID" | cut -d';' -f1)
echo -e "${CYAN}Submitted job ${JOBID} to ${CLUSTER} ${NC}"
}

function select_jobs {
    local action="${1:-cancel}"
    local raw
    mapfile -t raw < <(squeue -u "$USER" --clusters "$CLUSTER" 2>/dev/null \
                        | grep -v '^CLUSTER:')

    if [[ ${#raw[@]} -le 1 ]]; then
        echo -e "${YELLOW}No jobs found for $USER on cluster '$CLUSTER'.${NC}"
        return 0
    fi

    echo -e "${CYAN}── Jobs for $USER on '$CLUSTER' ──${NC}"
    echo -e "${CYAN}       ${raw[0]}${NC}"  # header
    for i in "${!raw[@]}"; do
        [[ $i -eq 0 ]] && continue
        echo -e "  ${CYAN}[$((i-1))]${NC}  ${raw[$i]}"
    done

    echo ""
    case $action in
        log) read -r -p "Enter index of job to view log (e.g. 1): " selection ;;
        cancel) read -r -p "Enter comma-separated indices to cancel (e.g. 0,2,3): " selection ;;
        usage)  read -r -p "Enter index of job to display usage (e.g. 1): " selection ;;
    esac

    local all_ids=()
    for i in "${!raw[@]}"; do
        [[ $i -eq 0 ]] && continue
        all_ids+=("$(awk '{print $1}' <<< "${raw[$i]}")")
    done

    local selected_ids=()
    IFS=',' read -ra indices <<< "$selection"
    for idx in "${indices[@]}"; do
        idx="${idx// /}"
        if [[ ! "$idx" =~ ^[0-9]+$ ]] || (( idx >= ${#all_ids[@]} )); then
            echo -e "${RED}Invalid index: $idx — skipping.${NC}" >&2
            continue
        fi
        selected_ids+=("${all_ids[$idx]}")
    done

    if [[ ${#selected_ids[@]} -eq 0 ]]; then
        echo -e "${YELLOW}No valid jobs selected.${NC}"
        return 0
    fi

    JOBS=$(IFS=','; echo "${selected_ids[*]}")
}

function get_jobs {
    # JOBS already set explicitly via -j: use as-is.
    if [[ -n "$JOBS" ]]; then
        return 0
    fi

    # last line is the most recently submitted job.
    local all_ids
    all_ids=$(squeue -u "$USER" --clusters "$CLUSTER" -h -o '%i %V' 2>/dev/null | sort -k2 | awk '{print $1}')

    if [[ -z "$all_ids" ]]; then
        echo -e "${YELLOW}No jobs found for $USER on cluster '$CLUSTER'.${NC}" >&2
        return 0
    fi

    if [[ "$SCOPE" == "all" ]]; then
        JOBS=$(echo "$all_ids" | tr '\n' ',' | sed 's/,$//')
    else
        # Default: most recently submitted job only.
        JOBS=$(echo "$all_ids" | tail -n 1)
    fi
}

function cancel_jobs {
    # if requested promt for job selection
    if [[ "$SELECT" == "true" ]]; then
        select_jobs "cancel"

        # if no jobs were selected, do not proceed.
        [[ -z "$JOBS" ]] && return 0
    fi

    get_jobs

    if [[ -z "$JOBS" ]]; then
        echo -e "${YELLOW}Nothing to cancel.${NC}"
        return 0
    fi

    echo -e "${CYAN}Jobs to cancel on '$CLUSTER': ${JOBS}${NC}"
    read -r -p "Are you sure you want to cancel these jobs? [y/N] " confirm
    if [[ "${confirm,,}" != "y" ]]; then
        echo "Aborted."
        return 0
    fi

    IFS=',' read -ra JOB_ARRAY <<< "$JOBS"
    if scancel --clusters "$CLUSTER" "${JOB_ARRAY[@]}"; then
        echo -e "${CYAN}Cancelled: ${JOBS}${NC}"
    else
        echo -e "${RED}scancel returned an error – check output above.${NC}" >&2
        return 1
    fi
}

function res_use {
    # if requested promt for job selection
    if [[ "$SELECT" == "true" ]]; then
        select_jobs "usage"

        # if no jobs were selected, do not proceed.
        [[ -z "$JOBS" ]] && return 0
    fi

    get_jobs

    if [[ -z "$JOBS" ]]; then
        echo -e "${YELLOW}No jobs to report on.${NC}"
        return 0
    fi
    IFS=',' read -ra JOB_ARRAY <<< "$JOBS"
    JOB="${JOB_ARRAY[-1]}"

    local step
    step=$(sacct -j "$JOB" --clusters "$CLUSTER" \
           --format=JobID%-30 2>/dev/null \
           | tr -d ' ' \
           | grep -v "^$JOB$" \
           | grep -v "\.extern$" \
           | tail -1)
    
    if [[ -z "$step" ]]; then
        echo -e "${RED}No active steps found for job $JOB.${NC}" >&2
        return 1
    fi
    
    echo -e "${CYAN}── sstat report for step $step ──${NC}"
    if [[ "$LIVE" == "true" ]];then
        watch -n $UPDATE_TIME sstat -j "$step" --format=AveCPU,AveRSS,MaxRSS || echo -e "${RED}sstat failed for job $JOB${NC}" >&2
    else
        sstat -j "$step" --format=AveCPU,AveRSS,MaxRSS || echo -e "${RED}sstat failed for job $JOB${NC}" >&2
    fi
}

function list_view {
    if [[ "$LIVE" == "true" ]];then
        watch -n $UPDATE_TIME squeue -u "$USER" --clusters "$CLUSTER"
    else
        squeue -u "$USER" --clusters "$CLUSTER"
    fi
}

function log_view {
    # if requested promt for job selection
    if [[ "$SELECT" == "true" ]]; then
        select_jobs "log"

        [[ -z "$JOBS" ]] && return 0
        if [[ "$JOBS" == *","* ]]; then
            echo -e "${YELLOW}Please select only one job.${NC}"
            return 0
        fi
    fi

    get_jobs
    [[ -z "$JOBS" ]] && { echo -e "${YELLOW}No jobs to report on.${NC}"; return 0; }

    IFS=',' read -ra JOB_ARRAY <<< "$JOBS"
    JOB="${JOB_ARRAY[-1]}"

    local job_name
    job_name=$(scontrol show job "$JOB" --clusters "$CLUSTER" | grep -oP 'JobName=\K\S+')

    [[ -z "$job_name" ]] && { echo -e "${RED}Could not resolve job name for $JOB.${NC}" >&2; return 1; }

    local log="$DATA/logs/${job_name}-${JOB}.log"

    [[ ! -f "$log" ]] && { echo -e "${RED}Log file not found: $log${NC}" >&2; return 1; }

    if [[ "$LIVE" == "true" ]]; then
        tail -f "$log"
    else
        cat "$log"
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Determine action
# ─────────────────────────────────────────────────────────────────────────────
case "${1:-help}" in
    help)   help; exit 0 ;;
    list)   ACTION="list" ;;
    usage)  ACTION="usage" ;;
    cancel) ACTION="cancel" ;;
    submit) ACTION="submit" ;;
    log)    ACTION="log" ;;
    *)      echo -e "${RED}Unknown action: $1${NC}" >&2; help; exit 64 ;;
esac
shift

# ─────────────────────────────────────────────────────────────────────────────
# Parse per-action options (after the action keyword)
# ─────────────────────────────────────────────────────────────────────────────
if [[ "$ACTION" == "list" ]]; then
    while getopts ":lC:" opts; do
        case $opts in
            l) LIVE="true" ;;
            C) CLUSTER="$OPTARG" ;;
            :) echo -e "${RED}Option -$OPTARG requires an argument.${NC}" >&2; help; exit 64 ;;
            *) echo -e "${RED}Illegal option -$OPTARG for ${ACTION}.${NC}" >&2; help; exit 64 ;;
        esac
    done
elif [[ "$ACTION" == "log" ]]; then
    while getopts ":lsj:C:" opts; do
        case $opts in
            l) LIVE="true" ;;
            s) SELECT="true" ;;
            j) JOBS="$OPTARG" ;;
            C) CLUSTER="$OPTARG" ;;
            :) echo -e "${RED}Option -$OPTARG requires an argument.${NC}" >&2; help; exit 64 ;;
            *) echo -e "${RED}Illegal option -$OPTARG for ${ACTION}.${NC}" >&2; help; exit 64 ;;
        esac
    done
elif [[ "$ACTION" == "usage" ]]; then
    while getopts ":lj:C:" opts; do
        case $opts in
            s) SELECT="true" ;;
            l) LIVE="true" ;;
            j) JOBS="$OPTARG" ;;
            C) CLUSTER="$OPTARG" ;;
            :) echo -e "${RED}Option -$OPTARG requires an argument.${NC}" >&2; help; exit 64 ;;
            *) echo -e "${RED}Illegal option -$OPTARG for ${ACTION}.${NC}" >&2; help; exit 64 ;;
        esac
    done
elif [[ "$ACTION" == "cancel" ]]; then
    while getopts ":asj:C:" opts; do
        case $opts in
            s) SELECT="true" ;;
            j) JOBS="$OPTARG" ;;
            a) SCOPE="all" ;;
            C) CLUSTER="$OPTARG" ;;
            :) echo -e "${RED}Option -$OPTARG requires an argument.${NC}" >&2; help; exit 64 ;;
            *) echo -e "${RED}Illegal option -$OPTARG for ${ACTION}.${NC}" >&2; help; exit 64 ;;
        esac
    done
elif [[ "$ACTION" == "submit" ]]; then
    while getopts ":e:m:c:t:p:g:C:" opts; do
        case $opts in
            e) ENV4SCRIPT="$OPTARG" ;;
            m) MEM="$OPTARG" ;;
            c) CPUs="$OPTARG" ;;
            t) TIME="$OPTARG" ;;
            p) PARTITION="$OPTARG" ;;
            g) GPU="$OPTARG" ;;
            C) CLUSTER="$OPTARG" ;;
            :) echo -e "${RED}Option -$OPTARG requires an argument.${NC}" >&2; help; exit 64 ;;
            *) echo -e "${RED}Illegal option -$OPTARG for ${ACTION}.${NC}" >&2; help; exit 64 ;;
        esac
    done
    shift $((OPTIND - 1))
else
    echo -e "${RED}Illegal action ${ACTION}.${NC}" >&2; help; exit 64
fi

# ─────────────────────────────────────────────────────────────────────────────
# Dispatch
# ─────────────────────────────────────────────────────────────────────────────
case $ACTION in
    help)   help ;;
    list)   list_view ;;
    usage)  res_use ;;
    cancel) cancel_jobs ;;
    submit) submit "${@}" ;;
    log)    log_view ;;
esac

#!/bin/bash

GPU=""
MEM=32G
CPUs=8
TIME="08:00:00"
PARTITION="short"
CLUSTER="htc"
BATCH="false"
SCRIPT_PATH=$(realpath "$0")

function help {
cat <<EOF
Usage: $(basename "$0") [-h] [-b] [-g GPU] [-m MEM] [-c CPUs] [-t TIME] [-p PARTITION] [-C CLUSTER]
  -h  help
  -b  run in batch mode via sbatch (default is interactive via srun)
  -g  request GPU (default: no GPU)
  -m  memory (default: $MEM)
  -c  CPUs (default: $CPUs)
  -t  walltime (default: $TIME)
  -p  partition (default: $PARTITION)
  -C  cluster (default: $CLUSTER)

Example: 
  nog_vscode_server -m 16G -c 8 -t 24:00:00 -p medium -C htc

Note:
  Do NOT use -b for the very first run. Use the default interactive job instead to complete the authentification.
EOF
}

function init_env_vars {
    export VSCODE_BASE="${DATA}/environments/vscode"
    export VSCODE_EXTENSIONS="${VSCODE_BASE}/.vscode-extensions"
    export VSCODE_CLI_DATA_DIR="${VSCODE_BASE}/.vscode-cli"
    export VSCODE_AGENT_FOLDER="${VSCODE_BASE}/.vscode-server"

    local REQ_ENV_PATHS=(
        "export VSCODE_BASE=\"${DATA}/environments/vscode\""
        "export VSCODE_EXTENSIONS=\"${VSCODE_BASE}/.vscode-extensions\""
        "export VSCODE_CLI_DATA_DIR=\"${VSCODE_BASE}/.vscode-cli\""
        "export VSCODE_AGENT_FOLDER=\"${VSCODE_BASE}/.vscode-server\""
    )

    for line in "${REQ_ENV_PATHS[@]}"; do
        grep -qxF "$line" $HOME/.bashrc || echo "$line" >> $HOME/.bashrc
    done
}

function setup_tunnel {
    for line in "${REQ_ENV_PATHS[@]}"; do
      grep -qxF "$line" ~/.bashrc || echo "$line" >> ~/.bashrc
    done

    mkdir -p "${VSCODE_BASE}"

    # Cache the download: Only fetch if the binary doesn't exist
    if [[ ! -x "${VSCODE_BASE}/code" ]]; then
        echo "Downloading VS Code CLI..."
        curl -Lk 'https://code.visualstudio.com/sha/download?build=stable&os=cli-alpine-x64' --output "${VSCODE_BASE}/vscode_cli.tar.gz"
        tar -xf "${VSCODE_BASE}/vscode_cli.tar.gz" -C "${VSCODE_BASE}"
        rm "${VSCODE_BASE}/vscode_cli.tar.gz"
    fi

    "${VSCODE_BASE}/code" tunnel user login --provider microsoft && "${VSCODE_BASE}/code" tunnel --accept-server-license-terms
}

function new_session {
    local GPU_DIRECTIVE=""
    [[ -n "$GPU" ]] && GPU_DIRECTIVE="--gres=gpu:${GPU}"
    
    # Note: Unquoted $GPU_DIRECTIVE is intentional so Bash drops it if it's empty
    srun \
      --partition="$PARTITION" \
      $GPU_DIRECTIVE \
      --cpus-per-task="$CPUs" \
      --mem="$MEM" \
      --time="$TIME" \
      --job-name=vscode \
      --clusters="$CLUSTER" \
      --pty bash -c "source $HOME/.bashrc && source $SCRIPT_PATH && setup_tunnel"
}

function new_batch {
    local GPU_DIRECTIVE=""
    [[ -n "$GPU" ]] && GPU_DIRECTIVE="#SBATCH --gres=gpu:${GPU}"

    local JOBID
    JOBID=$(sbatch --parsable <<EOF
#!/bin/bash
#SBATCH --partition=$PARTITION
#SBATCH --job-name=vscode
#SBATCH --cpus-per-task=$CPUs
#SBATCH --mem=$MEM
#SBATCH --time=$TIME
#SBATCH --clusters=$CLUSTER
#SBATCH --output=$DATA/logs/vscode-%j.log
#SBATCH --error=$DATA/logs/vscode-%j.log
${GPU_DIRECTIVE:-}

source "$HOME/.bashrc"
source "$SCRIPT_PATH"
setup_tunnel
EOF
)
    JOBID=$(echo "$JOBID" | cut -d';' -f1)
    echo "Job ${JOBID} submitted! Waiting for VSCode to start ..."
    
    until [[ -f "$DATA/logs/vscode-${JOBID}.log" ]]; do 
        sleep 2s
    done 
    tail -f "$DATA/logs/vscode-${JOBID}.log"
}

function main {
    while getopts "hbg:m:c:t:p:C:" opts ; do
        case $opts in
            h) help; exit 0 ;;
            b) BATCH="true" ;;
            g) GPU="$OPTARG";;
            m) MEM="$OPTARG";;
            c) CPUs="$OPTARG";;
            C) CLUSTER="$OPTARG";;
            t) TIME="$OPTARG";;
            p) PARTITION="$OPTARG";;
            *) echo "illegal option" >&2; help; exit 64 ;;
        esac
    done

    init_env_vars

    mkdir -p "$DATA/logs"
    
    if [[ "$BATCH" == "true" ]]; then
        new_batch
    else
        new_session
    fi
}

[[ "${BASH_SOURCE[0]}" == "$0" ]] && main "$@"
